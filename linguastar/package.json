    "dev": "cd frontend && next dev",
    "prebuild": "node -e \"if(require('fs').existsSync('.env.local')) require('fs').copyFileSync('.env.local', 'frontend/.env.local')\"",
    "build": "cd frontend && next build",
    "start": "cd frontend && next start",
    "lint": "cd frontend && next lint"
  },
  "dependencies": {
